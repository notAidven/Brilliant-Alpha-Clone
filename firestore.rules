rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // users/{uid} profile + gamification fields:
    //   level (int >= 1), totalXp (int >= 0), streak (int >= 0),
    //   lastActivityDate (string YYYY-MM-DD or null)
    function validGamificationFields(data) {
      return (!('level' in data) || (data.level is int && data.level >= 1))
        && (!('totalXp' in data) || (data.totalXp is int && data.totalXp >= 0))
        && (!('streak' in data) || (data.streak is int && data.streak >= 0))
        && (!('lastActivityDate' in data)
          || data.lastActivityDate == null
          || (data.lastActivityDate is string
            && data.lastActivityDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && validGamificationFields(request.resource.data);
      allow update: if isOwner(userId) && validGamificationFields(request.resource.data);

      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Public read enables username → email lookup before sign-in.
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update, delete: if false;
    }
  }
}
