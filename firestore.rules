rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // users/{uid} profile + gamification fields:
    //   level (int >= 1), totalXp (int >= 0), streak (int >= 0),
    //   lastActivityDate (string YYYY-MM-DD or null),
    //   chips (int >= 0), bankrollGranted (bool) — Phase 2 casino bankroll,
    //   casinoNetWinnings (number, may be negative) — Phase 3 lifetime net winnings.
    function validGamificationFields(data) {
      return (!('level' in data) || (data.level is int && data.level >= 1))
        && (!('totalXp' in data) || (data.totalXp is int && data.totalXp >= 0))
        && (!('streak' in data) || (data.streak is int && data.streak >= 0))
        && (!('lastActivityDate' in data)
          || data.lastActivityDate == null
          || (data.lastActivityDate is string
            && data.lastActivityDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')))
        && (!('chips' in data) || (data.chips is int && data.chips >= 0))
        && (!('bankrollGranted' in data) || data.bankrollGranted is bool)
        && (!('casinoNetWinnings' in data) || data.casinoNetWinnings is number);
    }

    // Whitelist of every field the app ever writes to a user doc. Blocks
    // injecting arbitrary fields (M1).
    function validUserFields(data) {
      return data.keys().hasOnly([
        'email', 'username', 'profileAnimal', 'profileComplete',
        'level', 'totalXp', 'streak', 'lastActivityDate',
        'chips', 'bankrollGranted', 'casinoNetWinnings', 'createdAt'
      ]);
    }

    // House Standings leaderboard row (Phase 3 Casino Floor): a small public
    // projection of a player's lifetime net. World-readable to any signed-in user,
    // but each player may only ever write THEIR OWN row, in this exact shape.
    // `netWinnings` is a signed number (sessions can lose). Play-money + client
    // written by design — the shape + ownership pin are the protection.
    function validLeaderboardDoc(data, uid) {
      return data.keys().hasOnly(['uid', 'username', 'profileAnimal', 'netWinnings', 'updatedAt'])
        && data.uid == uid
        && data.username is string
        && data.username.size() <= 40
        && (data.profileAnimal == null || data.profileAnimal is string)
        && data.netWinnings is number
        && data.updatedAt is timestamp;
    }

    // True iff, AFTER this atomic commit, usernames/{key} exists and points at the
    // caller. Uses *After (not get/exists) on purpose: signup (completeProfileSetup)
    // and the Account-settings rename both write users/{uid}.username TOGETHER WITH
    // the usernames index doc in ONE transaction, so the index claim is visible to
    // getAfter/existsAfter. `key` is a plain variable (no method calls in the path).
    function ownsUsernameKey(key) {
      return existsAfter(/databases/$(database)/documents/usernames/$(key))
        && getAfter(/databases/$(database)/documents/usernames/$(key)).data.uid == request.auth.uid;
    }

    // The display username maps to its index doc via lower-case (normalizeUsername in
    // lib/userProfile.ts). A non-string username can never own an index doc, so it is
    // rejected. A write that sets a display username the caller does NOT own in the
    // index is denied (M3 impersonation / index desync).
    function ownsUsername(name) {
      return name is string && ownsUsernameKey(name.lower());
    }

    // Identity fields are constrained on update (M1), but the owner may change them
    // through Account settings:
    //  - email may only be set to the caller's VERIFIED auth-token email (Firebase
    //    lowercases it) or left unchanged. So the app can reconcile users/{uid}.email
    //    after a verifyBeforeUpdateEmail change, but a profile can NEVER point at an
    //    address the user has not proven they own.
    //  - username may be absent, null, UNCHANGED, or changed to a name the caller
    //    OWNS in the usernames index after this commit. Previously any string was
    //    accepted, letting a profile display a username it doesn't own in the index
    //    (M3 impersonation / index desync). The "unchanged" branch keeps every other
    //    profile write cheap — chips/bankrollGranted/gamification/email reconcile all
    //    leave username untouched, so they never trigger the index lookup.
    function identityFieldsValid(prev, next) {
      return (!('email' in next)
          || next.email == request.auth.token.email
          || (('email' in prev) && next.email == prev.email))
        && (!('username' in next)
          || next.username == null
          || (('username' in prev) && next.username == prev.username)
          || ownsUsername(next.username));
    }

    // On create there is no prior doc to compare, so a non-null username must be one
    // the caller owns in the index after this commit (completeProfileSetup writes
    // users/{uid} + usernames/{name} in the same transaction, so this passes).
    function usernameOwnedOnCreate(data) {
      return !('username' in data)
        || data.username == null
        || ownsUsername(data.username);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && validUserFields(request.resource.data)
        && validGamificationFields(request.resource.data)
        && usernameOwnedOnCreate(request.resource.data);
      allow update: if isOwner(userId)
        && validUserFields(request.resource.data)
        && validGamificationFields(request.resource.data)
        && identityFieldsValid(resource.data, request.resource.data);

      match /lessonProgress/{lessonId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Username → email lookup before sign-in. Single-doc `get` is public so the
    // login form can resolve an exact username, but `list` is blocked so the
    // collection can't be enumerated / bulk-harvested (C1). Each doc holds only
    // {uid, email}; create is pinned to the caller's own uid + token email and
    // that exact key set (C1/M2).
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      // Claim a free username: it must not already exist and must point to the
      // caller's own uid + verified token email (C1/M2). Used by signup AND by an
      // Account-settings username change (which deletes the old doc in the same op).
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly(['uid', 'email']);
      // Reconcile the stored email after a verified email change. Owner-only, the
      // uid can never change, and the email can only be set to the caller's own
      // verified token email — so the username -> email sign-in lookup stays valid
      // without ever letting someone point a name at an address they don't own.
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly(['uid', 'email']);
      // Release a username you own (so it can be re-claimed during a rename). A
      // user may ONLY delete a usernames doc that points to their own uid.
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // House Standings leaderboard (Phase 3 Casino Floor). Any signed-in user may
    // read the board; a player may only create/update THEIR OWN row, and only with
    // the validated shape above (uid pinned to their own uid). No deletes.
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && validLeaderboardDoc(request.resource.data, uid);
    }
  }
}
