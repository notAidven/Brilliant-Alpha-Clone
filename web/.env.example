# Firebase Web app config — Firebase Console → Project settings → Your apps → Web
# Project: https://console.firebase.google.com/project/brilliant-alpha-clone-54be9/overview

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=brilliant-alpha-clone-54be9.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=brilliant-alpha-clone-54be9
VITE_FIREBASE_STORAGE_BUCKET=brilliant-alpha-clone-54be9.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- LLM provider (optional; until set, the app uses built-in rule-based fallback) ---
# Default provider is "gemini" (Firebase AI Logic, configured above) — leaving all of
# the below blank keeps the current behavior. Set a key (or proxy) to switch providers
# with NO code changes.
# VITE_LLM_PROVIDER=gemini   # gemini | openai | anthropic (auto-detected from keys if unset)
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# Optional model overrides (otherwise sensible defaults in providers/openai.ts & anthropic.ts):
# VITE_OPENAI_MODEL=
# VITE_ANTHROPIC_MODEL=
# SECURITY: a raw key here is exposed in the browser bundle. For production, leave keys blank
# and set a backend proxy instead (it injects the real key server-side):
# VITE_LLM_PROXY_URL=
